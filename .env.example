# ─────────────────────────────────────────────────────────────────────────────
# Dark Thila X MD — Environment Variables
# Copy this file to .env and fill in the values.
# ─────────────────────────────────────────────────────────────────────────────

# Server port (Railway / Heroku set this automatically — do NOT set manually there)
PORT=8080

# Node environment: development | production
# Must be "production" on Railway/Heroku so the API serves the built frontend.
NODE_ENV=production

# ── Auth ──────────────────────────────────────────────────────────────────────
# Long random string used to sign dashboard JWT tokens.
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-secret

SESSION_SECRET=change-me-to-another-random-secret

# ── Database (optional) ───────────────────────────────────────────────────────
# PostgreSQL for the user/login store.
# If unset the bot still works but dashboard login may use an in-memory store.
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── WhatsApp session persistence (STRONGLY recommended on cloud deploys) ──────
# Without this, Baileys stores auth in SQLite which is wiped on every redeploy.
# Set to a MongoDB Atlas free-tier URI to keep sessions across redeploys.
# MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/dark-thila?retryWrites=true&w=majority

# ── AI chat (.ai command) ─────────────────────────────────────────────────────
# Google Gemini API key — free tier at https://aistudio.google.com
# Falls back to Pollinations (free, no key) if unset.
# GEMINI_API_KEY=AIza...

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info
